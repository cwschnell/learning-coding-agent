# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=password

# Company Database Names
DB_NAME_1=company1_db
DB_NAME_2=company2_db

# Company Data Directories
COMPANY1_DIR=/var/data/company1
COMPANY2_DIR=/var/data/company2

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# PDF Processing Configuration
PDFTOPPM_BIN=/usr/bin/pdftoppm
PDF_RENDER_DPI=110
PDF_MAX_PAGES=8